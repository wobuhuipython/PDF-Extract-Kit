# 千问 API 配置
OPENAI_API_KEY=sk-xxxxxxxxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_FOLDER_PATH=
OSS_DOMAIN=

# NocoDB 配置
NOCODB_API_URL=
NOCODB_API_TOKEN=
NOCODB_TABLE_ID=
NOCODB_BASE_ID=

# 提取配置
MIN_CONFIDENCE=0.9
CAPTION_DISTANCE=200
SAVE_LOCAL_IMAGES=false


# PDF 文本提取配置
EXTRACT_FULL_TEXT=true
MAX_TEXT_PAGES=0  # 0 表示提取所有页，设置具体数字可限制页数（如 10）

# OCR 过滤配置
ENABLE_OCR_FILTER=true

# OSS 下载缓存配置
# OSS_CACHE_DIR=E:/langextract/PDF-Extract-Kit/cache  # 自定义缓存目录（留空则使用系统临时目录）